# ============================================================
# Belenay Mobilya - Ortam Değişkenleri Örneği
# ============================================================
# Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri doldurun.

# ---- Veritabanı Ayarları ----
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ---- Redis Ayarları ----
REDIS_HOST=
REDIS_PORT=

# ---- JWT Token Ayarları ----
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=
JWT_REFRESH_EXPIRY=

# ---- Google OAuth Ayarları ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Apple OAuth Ayarları ----
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ---- API URL Ayarları ----
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=

# ---- Dosya Yükleme Ayarları ----
UPLOAD_PATH=

# ---- SMTP E-posta Ayarları ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ---- Better Auth Ayarları ----
BETTER_AUTH_SECRET=

# ---- Uygulama Ortamı ----
NODE_ENV=
